{
  "name": "easy-plugin",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=22.20.0 <23",
    "pnpm": ">=10.30.1 <11"
  },
  "scripts": {
    "builder:build": "pnpm --filter @easy-plugin/builder build",
    "build": "pnpm generate && pnpm --filter @easy-plugin/frontend build",
    "check": "pnpm --filter @easy-plugin/builder check && pnpm --filter @easy-plugin/frontend check",
    "dev": "pnpm --filter @easy-plugin/frontend dev",
    "generate": "pnpm builder:build && pnpm exec plugin generate",
    "test": "pnpm --filter @easy-plugin/builder test && pnpm --filter @easy-plugin/frontend test"
  },
  "devDependencies": {
    "@easy-plugin/builder": "workspace:*"
  }
}
